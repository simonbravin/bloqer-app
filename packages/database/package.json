{
  "name": "@repo/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:prod": "dotenv -e .env.production.local -- prisma migrate deploy",
    "db:seed": "tsx src/seed.ts",
    "db:seed-templates": "tsx src/seed-templates.ts",
    "db:seed-presupuesto-oficial": "tsx src/seed-presupuesto-oficial.ts",
    "db:seed-demo": "tsx src/seed-demo.ts",
    "db:seed-test-user": "tsx src/seed-test-user.ts",
    "db:backfill-paid-date": "tsx src/backfill-paid-date.ts",
    "set-bravin-admin": "tsx src/set-bravin-admin.ts",
    "set-bravin-owner": "tsx src/set-bravin-owner.ts",
    "set-org-role": "tsx src/set-org-role.ts",
    "set-bravin-password": "tsx src/set-bravin-password.ts",
    "set-superadmin-password": "tsx src/set-superadmin-password.ts",
    "db:create-superadmin:prod": "dotenv -e .env.production.local -- tsx src/set-superadmin-password.ts",
    "ensure-demo-org": "tsx src/ensure-demo-org.ts",
    "ensure-demo-org:prod": "dotenv -e .env.production.local -- tsx src/ensure-demo-org.ts",
    "build": "prisma generate",
    "lint": "echo \"Add lint\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0"
  }
}
